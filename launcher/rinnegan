#!/bin/sh
# rinnegan launcher: runs the bundled Node runtime, never a Node found in PATH.
set -e

# Walk the symlink chain by hand: readlink -f / realpath are not portable across macOS, BusyBox, and coreutils.
SELF=$0
case $SELF in
  */*) ;;
  *)
    RESOLVED=$(command -v -- "$SELF" 2>/dev/null || true)
    if [ -n "$RESOLVED" ]; then
      SELF=$RESOLVED
    fi
    ;;
esac
while [ -h "$SELF" ]; do
  LINK=$(readlink -- "$SELF")
  case $LINK in
    /*)
      SELF=$LINK
      ;;
    *)
      SELF=$(dirname -- "$SELF")/$LINK
      ;;
  esac
done

BINDIR=$(cd -P -- "$(dirname -- "$SELF")" && pwd)
ROOT=$(cd -P -- "$BINDIR/.." && pwd)
export RINNEGAN_ROOT="$ROOT"

NODE=$ROOT/runtime/bin/node
APP=$ROOT/lib/bin/rinnegan.js

# Strip com.apple.quarantine so Gatekeeper will run the bundled node; ignore errors so startup never blocks.
if [ "$(uname -s)" = "Darwin" ]; then
  xattr -d -r com.apple.quarantine "$ROOT" >/dev/null 2>&1 || true
fi

# Inject a default --config unless the user supplied one, so bare `rinnegan` works.
HAS_CONFIG=0
for arg in "$@"; do
  if [ "$arg" = "--config" ]; then
    HAS_CONFIG=1
    break
  fi
done

# exec so signals (SIGINT/SIGTERM) propagate to node and PID stays stable.
if [ "$HAS_CONFIG" -eq 1 ]; then
  exec "$NODE" "$APP" "$@"
else
  exec "$NODE" "$APP" "$@" --config "$ROOT/config.json"
fi
