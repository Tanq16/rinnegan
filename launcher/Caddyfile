# skip_install_trust: never touch any system/NSS/Java trust store or shell out to sudo.
{
	admin off
	auto_https disable_redirects
	skip_install_trust
	default_sni localhost
	servers {
		timeouts {
			read_header 10s
			read_body 30s
		}
	}
}

# Two addresses: `https://localhost:8443` gives `tls internal` a subject to mint a cert; host-less `https://:8443` routes IP-literal Host headers (e.g. 127.0.0.1) to the proxy.
https://localhost:8443, https://:8443 {
	bind 0.0.0.0 ::
	tls internal
	request_body {
		max_size 4MB
	}
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
		-Server
	}
	reverse_proxy 127.0.0.1:8442
}
