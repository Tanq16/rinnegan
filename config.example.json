{
  "listen": {
    "host": "127.0.0.1",
    "port": 8787
  },
  "cookie": {
    "secure": true,
    "name": "rinnegan",
    "ttlSeconds": 86400
  },
  "terminal": {
    "shell": "/usr/bin/env zsh -l",
    "cwd": "/home/ubuntu",
    "cols": 120,
    "rows": 36,
    "autoRestartShell": false,
    "env": {
      "TERM": "xterm-256color",
      "COLORTERM": "truecolor",
      "LANG": "en_US.UTF-8",
      "LC_ALL": "en_US.UTF-8"
    }
  },
  "control": {
    "mode": "soft",
    "staleControllerSeconds": 120,
    "requestTimeoutSeconds": 60
  },
  "buffer": {
    "maxBytes": 2097152
  },
  "usersFile": "./users.json",
  "stateFile": "./state.json"
}
